# joplin-mcp configuration template.
# Copy this file to `.env` and fill in your token. The .env file is
# git-ignored. Shell-set env vars always win over values in this file.

# Required: Joplin Web Clipper API token.
# Joplin Desktop → Tools → Options → Web Clipper → enable + copy token.
JOPLIN_TOKEN=your-token-here

# Optional: Joplin Web Clipper base URL. Defaults to http://localhost:41184.
# JOPLIN_BASE_URL=http://localhost:41184

# Optional: per-request HTTP timeout (Go duration syntax: 10s, 1m, 500ms).
# JOPLIN_TIMEOUT=10s

# Optional: log level (debug, info, warn, error).
# JOPLIN_LOG_LEVEL=info

# Optional: max bytes for download_resource and upload_resource. 50 MiB default.
# JOPLIN_MAX_RESOURCE_BYTES=52428800

# Set to 1 to enable end-to-end tests against a real Joplin Desktop.
# JOPLIN_E2E=1
